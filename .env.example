TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=app

# Listing media storage. Keep S3_PUBLIC_BASE_URL empty for private buckets;
# the API will serve images through /api/media/:token.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
API_PUBLIC_BASE_URL=http://localhost:3333

# ── Sprint 2 — Email transaccional (Resend) ──────────────────────────────
# Bloqueante para que el email "Nuevo lead recibido" llegue al agente.
# Sin RESEND_API_KEY el lead se persiste pero el email se loggea como warning.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Gabana <noreply@gabanarealstate.com.mx>
SUPPORT_EMAIL=hola@gabanarealstate.com.mx

# URLs base usadas para construir los links que aparecen en los emails.
ADMIN_BASE_URL=http://localhost:5173
PUBLIC_SITE_BASE_URL=http://localhost:3000

# ── Sprint 2 — Cloudflare Turnstile (DIFERIDO a Sprint 7) ────────────────
# DECISIÓN HUMANA (2026-04-26): Sprint 2-6 corre con stub. Cuando llegue
# Sprint 7, configura el sitio en https://dash.cloudflare.com → Turnstile,
# pega el Secret Key aquí y el servicio empieza a validar sin tocar código.
# Mientras tanto, la mitigación activa es el rate limit 5/min/IP.
TURNSTILE_SECRET_KEY=
